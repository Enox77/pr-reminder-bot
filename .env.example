# Copy this file to .env.local or reference it directly - see README for setup.
# Do NOT commit a filled-in version of this file to any public repo.

# GitHub token: Settings > Developer settings > Fine-grained tokens
# Needs "Pull requests: Read-only" permission on the repos you list below.
GITHUB_TOKEN=

# Slack Incoming Webhook URL: api.slack.com/apps > your app > Incoming Webhooks
SLACK_WEBHOOK_URL=

# One or more repos to check, comma-separated, format owner/repo
REPO_LIST=youruser/yourrepo,youruser/anotherrepo

# How many hours a PR can sit unreviewed before it's flagged as stale
THRESHOLD_HOURS=24
